{
  "root": true,
  "env": {
    "es2021": true,
    "node": true
  },
  "extends": [
    "eslint:recommended"
  ],
  "parserOptions": {
    "ecmaVersion": "latest"
  },
  "ignorePatterns": [
    "node_modules/"
  ],
  "rules": {
    "no-unused-vars": [
      "error",
      {
        "argsIgnorePattern": "^_"
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "public/**/*.js"
      ],
      "env": {
        "browser": true,
        "node": false
      }
    },
    {
      "files": [
        "tests/**/*.js"
      ],
      "env": {
        "node": true
      }
    }
  ]
}
